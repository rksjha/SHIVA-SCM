NODE_ENV=production
PORT=5000

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Option 1 — Railway (RECOMMENDED):
#   Railway sets DATABASE_URL automatically when you add PostgreSQL plugin.
#   No additional config needed — just leave DATABASE_URL set.
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# Option 2 — Docker / Manual PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=shiva_scm
# DB_USER=postgres
# DB_PASSWORD=shivascm2025

# Quick Docker one-liner:
# docker run -d --name shiva_scm_db \
#   -e POSTGRES_DB=shiva_scm \
#   -e POSTGRES_USER=postgres \
#   -e POSTGRES_PASSWORD=shivascm2025 \
#   -p 5432:5432 postgres:15-alpine

# ─── CORS ────────────────────────────────────────────────────────────────────
# Leave blank for Railway (single service).
# Set if deploying frontend separately:
# CORS_ORIGIN=https://your-frontend.up.railway.app
